diff --git a/net/minecraft/server/network/PlayerChunkSender.java b/net/minecraft/server/network/PlayerChunkSender.java
index 373da9d604cfb1614a0618d856aefd2be3c7682b..9cfaebe0e3b4368b2baab81ffa1afc30fe19e1f8 100644
--- a/net/minecraft/server/network/PlayerChunkSender.java
+++ b/net/minecraft/server/network/PlayerChunkSender.java
@@ -83,6 +83,9 @@ public class PlayerChunkSender {
         final boolean shouldModify = level.chunkPacketBlockController.shouldModify(connection.player, chunk);
         connection.send(new ClientboundLevelChunkWithLightPacket(chunk, level.getLightEngine(), null, null, shouldModify));
         // Paper end - Anti-Xray
+        // DeerFoliaPlus start - Servux structure tracking
+        org.leavesmc.leaves.protocol.servux.ServuxStructuresProtocol.onStartedWatchingChunk(connection.player, chunk);
+        // DeerFoliaPlus end - Servux structure tracking
         // Paper start - PlayerChunkLoadEvent
         if (io.papermc.paper.event.packet.PlayerChunkLoadEvent.getHandlerList().getRegisteredListeners().length > 0) {
             new io.papermc.paper.event.packet.PlayerChunkLoadEvent(new org.bukkit.craftbukkit.CraftChunk(chunk), connection.getPlayer().getBukkitEntity()).callEvent();
diff --git a/net/minecraft/server/network/ServerCommonPacketListenerImpl.java b/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
index 963afbe66765096213b4b7cdd664f8dba2021afa..485445918b67ef6e5acdfdb2c7c4c8d9500ccaf7 100644
--- a/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
+++ b/net/minecraft/server/network/ServerCommonPacketListenerImpl.java
@@ -194,6 +194,15 @@ public abstract class ServerCommonPacketListenerImpl implements ServerCommonPack
                 this.playerBrand = new net.minecraft.network.FriendlyByteBuf(io.netty.buffer.Unpooled.wrappedBuffer(data)).readUtf(256);
             }
 
+            // DeerFoliaPlus start - Leaves protocol support
+            if (this instanceof ServerGamePacketListenerImpl gamePacketListener) {
+                net.minecraft.resources.Identifier resId = net.minecraft.resources.Identifier.tryParse(identifier.toString());
+                if (resId != null && org.leavesmc.leaves.protocol.core.LeavesProtocolManager.handleRawPayload(gamePacketListener.player, resId, data)) {
+                    return;
+                }
+            }
+            // DeerFoliaPlus end - Leaves protocol support
+
             this.cserver.getMessenger().dispatchIncomingMessage(paperConnection(), identifier.toString(), data);
         } catch (final Exception e) {
             LOGGER.error("Couldn't handle custom payload on channel {}", identifier, e);
